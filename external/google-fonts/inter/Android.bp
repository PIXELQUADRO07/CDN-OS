package {
    default_applicable_licenses: [
        "external_google-fonts_inter_license",
    ],
}

license {
    name: "external_google-fonts_inter_license",
    visibility: [":__subpackages__"],
    license_kinds: [
        "SPDX-license-identifier-OFL",
    ],
    license_text: [
        "NOTICE",
    ],
}

prebuilt_font {
    name: "Inter-Regular.ttf",
    src: "Inter-Regular.ttf",
}

prebuilt_font {
    name: "Inter-Italic.ttf",
    src: "Inter-Italic.ttf",
}

prebuilt_font {
    name: "Inter-Medium.ttf",
    src: "Inter-Medium.ttf",
}

prebuilt_font {
    name: "Inter-MediumItalic.ttf",
    src: "Inter-MediumItalic.ttf",
}

prebuilt_font {
    name: "Inter-Bold.ttf",
    src: "Inter-Bold.ttf",
}

prebuilt_font {
    name: "Inter-BoldItalic.ttf",
    src: "Inter-BoldItalic.ttf",
}

filegroup {
    name: "Inter",
    srcs: ["font_config.json"],
    required: [
        "Inter-Regular.ttf",
        "Inter-Italic.ttf",
        "Inter-Medium.ttf",
        "Inter-MediumItalic.ttf",
        "Inter-Bold.ttf",
        "Inter-BoldItalic.ttf",
    ],
}
