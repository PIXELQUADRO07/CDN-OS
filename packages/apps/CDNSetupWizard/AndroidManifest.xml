<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="cdnos.setupwizard">

    <!-- ── Rete ──────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <!-- Permessi privilegiati Wi-Fi (disponibili solo per system app) -->
    <uses-permission android:name="android.permission.NETWORK_SETTINGS" />
    <uses-permission android:name="android.permission.OVERRIDE_WIFI_CONFIG" />

    <!-- ── Sistema ────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.CHANGE_CONFIGURATION" />
    <uses-permission android:name="android.permission.SET_TIME_ZONE" />
    <!-- WRITE_SECURE_SETTINGS e WRITE_GLOBAL_SETTINGS necessitano di privileged -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.WRITE_GLOBAL_SETTINGS" />

    <!-- ── Telefonia ──────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.MODIFY_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- ── UI & Lockscreen ────────────────────────────────────────────────── -->
    <!-- Necessario per FLAG_DISMISS_KEYGUARD e FLAG_SHOW_WHEN_LOCKED -->
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />

    <!-- ── Task management ────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <application
        android:name=".SetupWizardApp"
        android:allowBackup="false"
        android:icon="@drawable/ic_cdnos_logo"
        android:label="@string/app_name"
        android:theme="@style/Theme.CDNSetupWizard"
        android:supportsRtl="true">

        <!--
            SetupWizardActivity è dichiarata come HOME activity.
            Android la lancerà al boot al posto del launcher predefinito.
            Al termine del wizard l'activity:
              1. Scrive Settings.Secure.USER_SETUP_COMPLETE = 1
              2. Scrive Settings.Global.DEVICE_PROVISIONED = 1
              3. Lancia un intent ACTION_MAIN + CATEGORY_HOME per cedere
                 il controllo al launcher reale
        -->
        <activity
            android:name=".SetupWizardActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:immersive="true"
            android:configChanges="orientation|screenSize|keyboardHidden|locale"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">

            <!-- Intercetta il lancio del launcher al boot -->
            <intent-filter android:priority="99">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Action standard AOSP per il device setup wizard -->
            <intent-filter>
                <action android:name="android.intent.action.DEVICE_INITIALIZATION_WIZARD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Compatibility con SetupWizard standard -->
            <intent-filter>
                <action android:name="android.intent.action.SETUP_WIZARD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

    </application>

</manifest>
