<?xml version="1.0" encoding="utf-8"?>
<!--
    Logo vettoriale CDNOS — scudo stilizzato con lettera "C" e linee dinamiche.
    Gradiente viola → ciano per richiamare la palette del sistema.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="120">

    <!-- Cerchio esterno glow -->
    <path
        android:fillColor="#1A7C4DFF"
        android:pathData="M60,5 A55,55 0 1,1 59.9,5 Z" />

    <!-- Cerchio medio -->
    <path
        android:fillColor="#2A7C4DFF"
        android:pathData="M60,15 A45,45 0 1,1 59.9,15 Z" />

    <!-- Forma principale — esagono smussato -->
    <path
        android:fillColor="#7C4DFF"
        android:pathData="M60,22
            L85,36
            L85,64
            L75,78
            L45,78
            L35,64
            L35,36
            Z" />

    <!-- Lettera C stilizzata -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M72,43 A18,18 0 1,0 72,77" />

    <!-- Linea accent ciano in alto a destra -->
    <path
        android:strokeColor="#00E5FF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M78,30 L90,22" />

    <!-- Linea accent ciano in basso -->
    <path
        android:strokeColor="#00E5FF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M40,85 L80,85" />

    <!-- Punto ciano -->
    <path
        android:fillColor="#00E5FF"
        android:pathData="M88,20 A4,4 0 1,1 87.9,20 Z" />

</vector>
