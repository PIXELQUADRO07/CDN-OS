    <!-- Pagina 5 — Servizi Google -->
    <string name="google_title">Servizi Google</string>
    <string name="google_subtitle">Quale esperienza desideri?</string>
    <string name="google_none">Nessun servizio Google</string>
    <string name="google_microg">microG</string>
