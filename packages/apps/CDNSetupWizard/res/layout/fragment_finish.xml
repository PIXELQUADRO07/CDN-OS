<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome">

    <!-- Glow decorativo -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="#0D7C4DFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Logo pulsante -->
    <ImageView
        android:id="@+id/iv_finish_logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_cdnos_logo"
        android:contentDescription="CDNOS"
        app:layout_constraintBottom_toTopOf="@id/tv_finish_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38"
        android:layout_marginBottom="40dp" />

    <!-- Titolo -->
    <TextView
        android:id="@+id/tv_finish_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/finish_title"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/iv_finish_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_finish_subtitle" />

    <!-- Sottotitolo -->
    <TextView
        android:id="@+id/tv_finish_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/finish_subtitle"
        android:textColor="@color/accent_secondary"
        android:textSize="18sp"
        android:letterSpacing="0.04"
        android:textAlignment="center"
        android:layout_marginBottom="60dp"
        app:layout_constraintTop_toBottomOf="@id/tv_finish_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_finish" />

    <!-- Bottone finale -->
    <Button
        android:id="@+id/btn_finish"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_finish"
        android:background="@drawable/bg_button_primary"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toBottomOf="@id/tv_finish_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_installing" />

    <!-- Stato installazione -->
    <TextView
        android:id="@+id/tv_installing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/finish_installing"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
