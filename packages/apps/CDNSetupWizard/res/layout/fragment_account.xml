<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="08 / 09"
            style="@style/TextAppearance.CDNSetupWizard.SectionLabel"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/account_title"
            style="@style/TextAppearance.CDNSetupWizard.PageTitle"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/account_subtitle"
            style="@style/TextAppearance.CDNSetupWizard.PageSubtitle"
            android:layout_marginBottom="32dp"
            android:lineSpacingExtra="4dp" />

        <!-- Card crea account -->
        <LinearLayout
            android:id="@+id/card_account_yes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <RadioButton android:id="@+id/rb_account_yes"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/account_yes"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Nota "coming soon" -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/account_coming_soon"
                android:textColor="@color/accent_secondary"
                android:textSize="12sp"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <!-- Card senza account -->
        <LinearLayout
            android:id="@+id/card_account_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_selected"
            android:padding="20dp"
            android:layout_marginBottom="48dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <RadioButton android:id="@+id/rb_account_no"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_primary"
                    android:checked="true" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/account_no"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/btn_next"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
