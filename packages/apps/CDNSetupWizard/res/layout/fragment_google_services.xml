<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="05 / 09"
            style="@style/TextAppearance.CDNSetupWizard.SectionLabel"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/google_title"
            style="@style/TextAppearance.CDNSetupWizard.PageTitle"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/google_subtitle"
            style="@style/TextAppearance.CDNSetupWizard.PageSubtitle"
            android:layout_marginBottom="32dp" />

        <!-- Nessun Google -->
        <LinearLayout
            android:id="@+id/card_no_google"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_selected"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <RadioButton android:id="@+id/rb_no_google"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_primary"
                    android:checked="true" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/google_none"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/google_none_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- microG -->
        <LinearLayout
            android:id="@+id/card_microg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <RadioButton android:id="@+id/rb_microg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/google_microg"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/google_microg_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- GApps -->
        <LinearLayout
            android:id="@+id/card_gapps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <RadioButton android:id="@+id/rb_gapps"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/google_gapps"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/google_gapps_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- Warning GApps -->
        <TextView
            android:id="@+id/tv_gapps_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/google_warning_gapps"
            android:textColor="#FFAA00"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_next"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
