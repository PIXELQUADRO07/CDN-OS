<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="07 / 09"
            style="@style/TextAppearance.CDNSetupWizard.SectionLabel"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/security_title"
            style="@style/TextAppearance.CDNSetupWizard.PageTitle"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/security_subtitle"
            style="@style/TextAppearance.CDNSetupWizard.PageSubtitle"
            android:layout_marginBottom="32dp" />

        <!-- Firewall -->
        <LinearLayout android:id="@+id/card_firewall"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_card" android:padding="20dp"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/security_firewall"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/security_firewall_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_firewall"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- DNS over HTTPS -->
        <LinearLayout android:id="@+id/card_doh"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_card" android:padding="20dp"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/security_doh"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/security_doh_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_doh"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Private DNS -->
        <LinearLayout android:id="@+id/card_private_dns"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_card" android:padding="20dp"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/security_private_dns"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/security_private_dns_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_private_dns"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- VPN automatica -->
        <LinearLayout android:id="@+id/card_vpn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_card" android:padding="20dp"
            android:layout_marginBottom="32dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/security_vpn"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/security_vpn_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_vpn"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="false"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/btn_next"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
