<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome">

    <!-- Cerchi decorativi di sfondo -->
    <View
        android:id="@+id/circle_glow_1"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="#0F7C4DFF"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp" />

    <View
        android:id="@+id/circle_glow_2"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#0A00E5FF"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp" />

    <!-- Logo animato -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_cdnos_logo"
        android:contentDescription="CDNOS Logo"
        app:layout_constraintBottom_toTopOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!-- Titolo CDNOS -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_title"
        android:textSize="52sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:letterSpacing="-0.03"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_subtitle" />

    <!-- Subtitle "Built for freedom." -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_subtitle"
        android:textSize="18sp"
        android:textColor="@color/accent_secondary"
        android:letterSpacing="0.04"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_start" />

    <!-- Bottone Inizia -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_start"
        android:background="@drawable/bg_button_primary"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_version_android" />

    <!-- Versioni in basso -->
    <TextView
        android:id="@+id/tv_version_android"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/os_version_android"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:letterSpacing="0.02"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/tv_version_cdnos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_version_cdnos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/os_version_cdnos"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
