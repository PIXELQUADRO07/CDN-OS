<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="org.cdnos.privacy.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_firewall"
            app:destination="@id/firewallFragment" />
        <action
            android:id="@+id/action_dashboard_to_permissions"
            app:destination="@id/permissionsFragment" />
        <action
            android:id="@+id/action_dashboard_to_network"
            app:destination="@id/networkFragment" />
        <action
            android:id="@+id/action_dashboard_to_selinux"
            app:destination="@id/selinuxFragment" />
    </fragment>

    <fragment
        android:id="@+id/firewallFragment"
        android:name="org.cdnos.privacy.FirewallFragment"
        android:label="Firewall"
        tools:layout="@layout/fragment_firewall" />

    <fragment
        android:id="@+id/permissionsFragment"
        android:name="org.cdnos.privacy.PermissionsFragment"
        android:label="Permissions"
        tools:layout="@layout/fragment_permissions" />

    <fragment
        android:id="@+id/networkFragment"
        android:name="org.cdnos.privacy.NetworkFragment"
        android:label="Network"
        tools:layout="@layout/fragment_network" />

    <fragment
        android:id="@+id/selinuxFragment"
        android:name="org.cdnos.privacy.SelinuxFragment"
        android:label="SELinux"
        tools:layout="@layout/fragment_selinux" />
</navigation>
